# Telephony service configuration.
# Copy this file to .env and fill in real values. .env is gitignored.

# HTTP + WS port the telephony service listens on.
TELEPHONY_PORT=4200

# What Exotel should connect back to. In dev set this to the ngrok / Cloudflare
# Tunnel host (without scheme). Set PUBLIC_WS_SCHEME=wss once you're behind TLS.
PUBLIC_WS_HOST=127.0.0.1:4200
PUBLIC_WS_SCHEME=ws

# Where the agent API (@msva/api) is reachable.
AGENT_BASE_URL=http://127.0.0.1:4100

# Passed to ASR + TTS adapters.
AGENT_LANGUAGE=hi-IN
# bulbul:v3 voices (May 2026): aditya, ritu, ashutosh, priya, neha, rahul,
# pooja, rohan, simran, kavya, amit, dev, ishita, shreya, ratan, varun, manan.
# The API will return the current list in any HTTP 400 for an unknown speaker.
TTS_VOICE=neha

# Sarvam streaming ASR + TTS. Leave blank to keep the stub adapters running.
# Get a key at https://dashboard.sarvam.ai
SARVAM_API_KEY=

# --- In-browser "Live Call" tuning (optional; defaults shown) ---------------
# The web app's Live Call screen streams 16 kHz PCM to ws://<host>/browser and
# reuses this same pipeline. These tune the energy VAD for browser mic input.
BROWSER_SAMPLE_RATE=16000
BROWSER_VAD_SILENCE_MS=750     # trailing silence before the agent answers
BROWSER_VAD_ENERGY_FLOOR=550   # raise if it false-triggers on background noise
BROWSER_VAD_MIN_VOICED_MS=280  # ignore endpoints before this much speech
BROWSER_BARGE_IN_MS=420        # how much caller speech interrupts the agent
