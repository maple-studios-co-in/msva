# Web app configuration. Copy to .env (gitignored) to override. All optional.

# Agent API base URL.
VITE_API_BASE_URL=http://localhost:4100

# Where the "Live Call" screen opens its WebSocket (the telephony service).
# Use wss://<host> when the app is served over HTTPS.
VITE_TELEPHONY_WS_URL=ws://localhost:4200
