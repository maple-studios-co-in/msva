# Copy to apps/api/.env on the server, then fill in SARVAM_API_KEY.
PORT=4100

# AI brain. Default OFF for a guaranteed-snappy live demo: instant deterministic
# Hinglish replies + heuristic tool calls (create_ticket / transfer / inventory).
# Set AGENT_LLM=on to use Ollama for real model-driven replies + order lookup
# (slower on a CPU-only box — see DEPLOY.md "AI brain" section).
AGENT_LLM=off
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_MS=30000

# Data files (paths are relative to apps/api).
CSV_PATH=../../data/reports.csv
ORDERS_PATH=../../data/orders.json
DEMO_FAILSAFE_CONFIG=../../data/demo-failsafe.json
DEMO_FAILSAFE_AUDIO=assets/demo-failsafe.mp3

# Sarvam ASR + TTS (required for real voice). Get a key at dashboard.sarvam.ai
SARVAM_API_KEY=__PUT_YOUR_SARVAM_KEY_HERE__
