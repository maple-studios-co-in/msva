# Copy to apps/api/.env on the server, then fill in SARVAM_API_KEY.
PORT=4100

# AI brain. AGENT_LLM=on enables the real model; =off uses instant deterministic
# replies (can also be toggled live in the app). LLM_PROVIDER picks the backend:
#   anthropic = hosted Claude — FAST even on a CPU box (recommended for this VPS)
#   ollama    = local model (free, but slow on 2 vCPU)
AGENT_LLM=on
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic). Get a key at console.anthropic.com
ANTHROPIC_API_KEY=__PUT_YOUR_ANTHROPIC_KEY_HERE__
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (used when LLM_PROVIDER=ollama).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_MS=30000

# Data files (paths are relative to apps/api).
CSV_PATH=../../data/reports.csv
ORDERS_PATH=../../data/orders.json
DEMO_FAILSAFE_CONFIG=../../data/demo-failsafe.json
DEMO_FAILSAFE_AUDIO=assets/demo-failsafe.mp3

# Sarvam ASR + TTS (required for real voice). Get a key at dashboard.sarvam.ai
SARVAM_API_KEY=__PUT_YOUR_SARVAM_KEY_HERE__
