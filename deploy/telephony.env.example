# Copy to apps/telephony/.env on the server, then fill in SARVAM_API_KEY.
TELEPHONY_PORT=4200
AGENT_BASE_URL=http://127.0.0.1:4100
AGENT_LANGUAGE=hi-IN
TTS_VOICE=neha
SARVAM_API_KEY=__PUT_YOUR_SARVAM_KEY_HERE__

# In-browser Live Call VAD tuning (optional; defaults shown).
BROWSER_SAMPLE_RATE=16000
BROWSER_VAD_SILENCE_MS=750
BROWSER_VAD_ENERGY_FLOOR=550
BROWSER_BARGE_IN_MS=420

# Real phone (Exotel) — only needed if you connect a DID. Exotel must reach
# this server at wss://msva.maplestudios.co.in/voice (Caddy proxies /voice).
PUBLIC_WS_HOST=msva.maplestudios.co.in
PUBLIC_WS_SCHEME=wss
